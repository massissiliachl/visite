    function initWebSocket() {
        if (ws && ws.readyState === WebSocket.OPEN) return;
        
        try {
            ws = new WebSocket(WS_URL);
            
            ws.onopen = () => {
                console.log('WebSocket connecté');
                updateConnectionStatus(true);
                reconnectAttempts = 0;
                
                // S'abonner aux réservations
                ws.send(JSON.stringify({ type: 'subscribe', channel: 'reservations' }));
                ws.send(JSON.stringify({ type: 'subscribe', channel: 'property-reservations' }));
            };
            
            ws.onmessage = (event) => {
                try {
                    const data = JSON.parse(event.data);
                    console.log('Message reçu:', data);
                    
                    switch(data.type) {
                        case 'new_reservation':
                            handleNewReservation(data.reservation);
                            break;
                        case 'new_property_reservation':
                            handleNewPropertyReservation(data.reservation);
                            break;
                        case 'reservation_updated':
                            handleReservationUpdate(data.reservation);
                            break;
                        case 'property_reservation_updated':
                            handlePropertyReservationUpdate(data.reservation);
                            break;
                        default:
                            console.log('Type de message non reconnu:', data.type);
                    }
                } catch(e) {
                    console.error('Erreur parse message:', e);
                }
            };
            
            ws.onerror = (error) => {
                console.error('WebSocket erreur:', error);
                updateConnectionStatus(false);
            };
            
            ws.onclose = () => {
                console.log('WebSocket déconnecté, tentative de reconnexion...');
                updateConnectionStatus(false);
                setTimeout(() => {
                    if (reconnectAttempts < 10) {
                        reconnectAttempts++;
                        initWebSocket();
                    }
                }, 3000);
            };
            
        } catch(e) {
            console.error('Erreur WebSocket:', e);
            updateConnectionStatus(false);
        }
    }
    
