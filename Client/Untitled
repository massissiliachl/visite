    async function loadBlockedDates(activity) {
        if (!activity) {
            document.getElementById('blockedDatesList').innerHTML = '<p>Sélectionnez une activité pour voir les dates bloquées.</p>';
            return;
        }
        try {
            const response = await fetch(`https://visitebejai.onrender.com/availability/${encodeURIComponent(activity)}`);
            if (response.ok) {
                const blockedDates = await response.json();
                blockedDatesByActivity[activity] = blockedDates;
                renderBlockedDates(activity);
            } else {
                blockedDatesByActivity[activity] = [];
                renderBlockedDates(activity);
            }
        } catch (error) {
            console.error('Erreur:', error);
            blockedDatesByActivity[activity] = [];
            renderBlockedDates(activity);
        }
    }
    
    function renderBlockedDates(activity) {
        const container = document.getElementById('blockedDatesList');
        const dates = blockedDatesByActivity[activity] || [];
        if (dates.length === 0) {
            container.innerHTML = '<p>Aucune date bloquée pour cette activité.</p>';
            return;
        }
        let html = '<div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">';
        dates.forEach(date => {
