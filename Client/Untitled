        `;
        document.getElementById('detailContent').innerHTML = detailHtml;
        document.getElementById('detailModal').classList.add('active');
    }
    
    function showPage(pageName) {
        document.querySelectorAll('.page-content').forEach(page => page.classList.remove('active-page'));
        const activePage = document.getElementById(`page-${pageName}`);
        if (activePage) activePage.classList.add('active-page');
        if (pageName === 'reservations-hebergement') fetchPropertyReservations();
        if (pageName === 'reservations') fetchReservations();
        document.querySelectorAll('.nav-item').forEach(nav => nav.classList.remove('active'));
        document.querySelector(`.nav-item[data-page="${pageName}"]`).classList.add('active');
    }
    
    document.getElementById('searchInput')?.addEventListener('input', applyFiltersAndRender);
    document.getElementById('statusFilter')?.addEventListener('change', applyFiltersAndRender);
    document.getElementById('refreshBtn')?.addEventListener('click', () => fetchReservations());
    document.getElementById('refreshPropertyBtn')?.addEventListener('click', () => fetchPropertyReservations());
    document.getElementById('propertySearchInput')?.addEventListener('input', renderPropertyReservations);
    document.getElementById('propertyStatusFilter')?.addEventListener('change', renderPropertyReservations);
    document.getElementById('closeDetailModal')?.addEventListener('click', () => document.getElementById('detailModal').classList.remove('active'));
    document.getElementById('activitySelect')?.addEventListener('change', (e) => loadBlockedDates(e.target.value));
    document.querySelectorAll('.nav-item').forEach(item => {
        item.addEventListener('click', () => showPage(item.dataset.page));
    });
    document.getElementById('detailModal')?.addEventListener('click', (e) => {
        if (e.target === document.getElementById('detailModal')) document.getElementById('detailModal').classList.remove('active');
    });
    
    window.updateStatus = updateStatus;
    window.deleteReservation = deleteReservation;
    window.viewDetails = viewDetails;
    window.blockDate = blockDate;
    window.unblockDate = unblockDate;
    window.updatePropertyStatus = updatePropertyStatus;
    window.deletePropertyReservation = deletePropertyReservation;
    window.viewPropertyDetails = viewPropertyDetails;
    window.saveSettings = saveSettings;
    
    initNotificationSound();
    loadSettings();
    fetchReservations();
    fetchPropertyReservations();
    startAutoRefresh();
    initWebSocket();
    
    if (Notification.permission === 'default') {
        setTimeout(() => Notification.requestPermission(), 1000);
    }
</script>
</body>
</html>